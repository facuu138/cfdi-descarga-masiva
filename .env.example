# RFC del contribuyente
SAT_RFC=XAXX010101000

# Ruta a los archivos de e.firma (.cer y .key)
# Recomendado: guardar fuera del repo
SAT_CERT_PATH=/ruta/a/tu/efirma.cer
SAT_KEY_PATH=/ruta/a/tu/efirma.key
SAT_KEY_PASSWORD=tu_contraseña

# Opcional: habilita logs de respuestas SOAP para depuración
# SAT_DEBUG=1
